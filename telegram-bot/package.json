{
  "name": "business-kz-telegram-bot",
  "version": "1.1.0",
  "private": true,
  "type": "commonjs",
  "main": "bot.js",
  "scripts": {
    "start": "node bot.js",
    "test": "node --test tests/*.test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,json,md,css,html,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{js,json,md,css,html,yaml,yml}\"",
    "db:migrate": "node scripts/apply-migrations.js",
    "db:backup": "node scripts/backup-db.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "node-telegram-bot-api": "^0.66.0",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "eslint": "^9.22.0",
    "globals": "^15.15.0",
    "prettier": "^3.5.2"
  }
}
